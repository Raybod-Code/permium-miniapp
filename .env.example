# ============================================================
# PREMIUM VPN MINIAPP — Environment Variables
# این فایل رو کپی کن به .env و مقادیر رو پر کن
# هرگز .env واقعی رو به گیت push نکن!
# ============================================================

# ─── DATABASE (Neon.tech PostgreSQL) ───────────────────────
# از داشبورد Neon → Connection Details بگیر
DATABASE_URL="postgresql://username:password@ep-xxx.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://username:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ─── TELEGRAM BOT ──────────────────────────────────────────
# از @BotFather بگیر
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"

# آدرس کامل Mini App (بعد از دیپلوی در Railway)
WEB_APP_URL="https://your-app.up.railway.app"

# Secret برای Webhook — یه string تصادفی امن
WEBHOOK_SECRET="your-random-secret-string-min-32-chars"

# ─── 3X-UI PANEL ───────────────────────────────────────────
# آدرس پنل 3x-ui روی سرور VPN
XUI_PANEL_URL="http://YOUR_SERVER_IP:2053"
XUI_USERNAME="admin"
XUI_PASSWORD="your-panel-password"
XUI_SECRET_PATH=""  # اگه secret path داری: "/mysecret"

# اطلاعات سرور برای ساخت لینک VLESS
XUI_SERVER_HOST="YOUR_SERVER_IP_OR_DOMAIN"
XUI_SERVER_PORT="443"
XUI_SERVER_SNI="www.google.com"

# ─── ADMIN ─────────────────────────────────────────────────
# Telegram ID ادمین اصلی (عدد)
ADMIN_TELEGRAM_ID="YOUR_TELEGRAM_ID"

# ─── CRYPTO PAYMENT ────────────────────────────────────────
# آدرس USDT TRC20 برای دریافت پرداخت
USER_WALLET_TRC20="YOUR_TRON_WALLET_ADDRESS"

# ─── NEXT.JS ───────────────────────────────────────────────
NEXTAUTH_SECRET="another-random-secret-min-32-chars"
NODE_ENV="development"

# برای تست لوکال (بدون تلگرام)
DEV_TEST_TELEGRAM_ID="YOUR_TELEGRAM_ID"
