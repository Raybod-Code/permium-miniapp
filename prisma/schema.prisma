generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String   @id @default(cuid())
  telegramId BigInt   @unique
  firstName  String
  username   String?
  balance    Float    @default(0.0)
  role       String   @default("USER")
  createdAt  DateTime @default(now())
}
